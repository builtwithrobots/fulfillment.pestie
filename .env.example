# ---------------------------------------------------------------------------
# Auth toggle (temporary, for building without logging in)
# Unset/false → no login required, app is open (a warning banner shows).
# true         → Clerk enforces sign-in on the dashboard. Enable before prod.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_AUTH=false

# ---------------------------------------------------------------------------
# Clerk (authentication) — https://dashboard.clerk.com → API keys
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Where Clerk sends users. These match the routes in src/app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---------------------------------------------------------------------------
# Supabase (database + realtime) — Project Settings → API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---------------------------------------------------------------------------
# Station-display tokens (signed JWTs for big-screen pairing)
# Generate a strong random value, e.g.  openssl rand -base64 48
# ---------------------------------------------------------------------------
TOKEN_SIGNING_SECRET=change-me-to-a-long-random-string
